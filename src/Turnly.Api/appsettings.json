{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "sqlite",
    "MigrateOnStartup": true
  },
  "ConnectionStrings": {
    "Default": "Data Source=turnly.db"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "Turnly",
    "Audience": "Turnly",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 180
  },
  "Auth": {
    "RefreshCookie": {
      "Secure": true,
      "Path": "/api/auth",
      "Name": "turnly_refresh"
    }
  },
  "Vapid": {
    "PublicKey": "",
    "PrivateKey": "",
    "Subject": "mailto:admin@example.com"
  },
  "Fcm": {
    "CredentialsPath": "",
    "CredentialsJson": ""
  },
  "Cors": {
    "Origins": []
  }
}
