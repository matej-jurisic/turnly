# Copy to `.env` and adjust. Docker Compose loads this automatically.

# REQUIRED: signing key for JWT access tokens. Use a long, random string, e.g.
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ISSUER=Turnly
JWT_AUDIENCE=Turnly

# Host port the app is published on.
PORT=8080

# Web Push (notifications). Generate one keypair once and keep it stable, e.g.
#   npx web-push generate-vapid-keys
# Leave blank to disable notifications (the background scheduler stays idle).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Standalone Android app (optional) ---------------------------------------
# Allow the native app's WebView origin so it can call this server. Leave blank
# if you don't use the Android app.
CORS_ORIGIN_ANDROID=https://localhost
# Native push via Firebase Cloud Messaging. Mount your Firebase service-account
# JSON into the container and point this at it (leave blank to disable). e.g.
#   FCM_CREDENTIALS_PATH=/run/secrets/firebase.json
FCM_CREDENTIALS_PATH=

# Set to false ONLY if serving over plain HTTP (e.g. local testing). In production,
# serve over HTTPS (typically behind a reverse proxy) and keep this true so the
# refresh-token cookie is marked Secure.
COOKIE_SECURE=true

# Database provider: sqlite (default) or postgres.
DATABASE_PROVIDER=sqlite
CONNECTION_STRING=Data Source=/data/turnly.db

# --- Postgres (only when DATABASE_PROVIDER=postgres) -------------------------
# Enable with: docker compose --profile postgres up --build
# and set CONNECTION_STRING, e.g.:
#   CONNECTION_STRING=Host=postgres;Port=5432;Database=turnly;Username=turnly;Password=turnly
# NOTE: Phase 1 ships SQLite migrations only; a Postgres migration set must be
# generated before first use.
POSTGRES_USER=turnly
POSTGRES_PASSWORD=turnly
POSTGRES_DB=turnly
